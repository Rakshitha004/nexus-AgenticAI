{
  "__inputs": [
    {
      "name": "DS_LOKI",
      "label": "Loki",
      "type": "datasource",
      "pluginId": "loki",
      "pluginName": "Loki"
    }
  ],
  "__requires": [
    { "type": "grafana",   "id": "grafana",    "name": "Grafana",    "version": "10.0.0" },
    { "type": "datasource","id": "loki",       "name": "Loki",       "version": "1.0.0"  },
    { "type": "panel",     "id": "timeseries", "name": "Time series","version": ""       },
    { "type": "panel",     "id": "logs",       "name": "Logs",       "version": ""       }
  ],
  "annotations": { "list": [] },
  "description": "All Docker container logs — Grafana Alloy collects from Docker socket and ships to Loki",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "refresh": "1m",
  "schemaVersion": 39,
  "tags": ["nexus", "loki", "alloy", "logs"],
  "title": "Docker Containers — Logs (Alloy → Loki)",
  "uid": "docker-containers-loki",
  "version": 1,
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "templating": {
    "list": [
      {
        "name": "container",
        "label": "Container",
        "type": "query",
        "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
        "refresh": 2,
        "query": "label_values(container)",
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "current": {},
        "hide": 0,
        "sort": 1
      }
    ]
  },
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Overview — All Containers",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "barAlignment": 0, "barWidthFactor": 0.8, "drawStyle": "bars",
            "fillOpacity": 100, "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineWidth": 1, "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never", "spanNulls": false,
            "stacking": { "group": "A", "mode": "normal" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 10, "w": 8, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum by (container) (count_over_time({container=~\"$container\"}[5m]))",
          "legendFormat": "{{container}}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Log Volume — All Containers",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 10, "w": 16, "x": 8, "y": 1 },
      "id": 3,
      "options": {
        "dedupStrategy": "none", "enableLogDetails": true,
        "prettifyLogMessage": false, "showCommonLabels": false,
        "showLabels": true, "showTime": true,
        "sortOrder": "Descending", "wrapLogMessage": false
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "{container=~\"$container\"}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "All Container Logs",
      "type": "logs"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 11 },
      "id": 10,
      "repeat": "container",
      "repeatDirection": "v",
      "title": "$container",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "barAlignment": 0, "barWidthFactor": 0.8, "drawStyle": "bars",
            "fillOpacity": 100, "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineWidth": 1, "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never", "spanNulls": false,
            "stacking": { "group": "A", "mode": "normal" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "info" },    "properties": [{ "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "warn" },    "properties": [{ "id": "color", "value": { "fixedColor": "#FADE2A", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "error" },   "properties": [{ "id": "color", "value": { "fixedColor": "#F2495C", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "unknown" }, "properties": [{ "id": "color", "value": { "fixedColor": "#5794F2", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 9, "w": 8, "x": 0, "y": 12 },
      "id": 11,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum by (level) (count_over_time({container=\"$container\"}[5m]))",
          "legendFormat": "{{level}}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "$container — Log Volume by Level",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 9, "w": 16, "x": 8, "y": 12 },
      "id": 12,
      "options": {
        "dedupStrategy": "none", "enableLogDetails": true,
        "prettifyLogMessage": false, "showCommonLabels": false,
        "showLabels": false, "showTime": true,
        "sortOrder": "Descending", "wrapLogMessage": false
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "{container=\"$container\"}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "$container — Logs",
      "type": "logs"
    }

  ]
}
